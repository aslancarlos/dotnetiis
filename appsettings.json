{
  "Database": {
    "Server": "your-db-host.example.com",
    "Port": 3306,
    "Name": "YourDb",
    "User": "your_db_user"
  },

  "CyberArk": {
    "AppId": "your-app-id",
    "Safe": "your-safe-name",
    "Folder": "Root",
    "Object": "your-account-object",
    "Reason": "WebApp DB connection via CyberArk Credential Provider"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

