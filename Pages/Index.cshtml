@page
@model ProductApp.Pages.IndexModel

@{
    ViewData["Title"] = "Lista de Produtos";
}

<h1>Produtos</h1>
<a asp-page="/Products/Create" class="btn btn-success mb-3">Novo Produto</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Descrição</th>
            <th>Preço (R$)</th>
            <th>Estoque</th>
            <th>Criado em</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Products)
    {
        <tr>
            <td>@p.Id</td>
            <td>@p.Name</td>
            <td>@p.Description</td>
            <td>@p.Price.ToString("N2")</td>
            <td>@p.Stock</td>
            <td>@p.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
        </tr>
    }
    </tbody>
</table>

